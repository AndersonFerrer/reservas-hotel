      "name": "Auth",
      "item": [
        {
          "name": "Registrar Cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombres\": \"Ana\",\n  \"apellidos\": \"Lopez\",\n  \"documento\": \"12345678\",\n  \"telefono\": \"999111222\",\n  \"email\": \"ana@correo.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register/cliente",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register",
                "cliente"
              ]
            }
          }
        },
        {
          "name": "Registrar Personal",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
